## 🧠 2. **Project IDX Environment** (`.idx/dev.nix`)

```nix
{ pkgs, ... }: {
  channel = "stable-23.11";
  packages = [
    pkgs.nodejs_20
    pkgs.nodePackages.firebase-tools
    pkgs.google-cloud-sdk
    pkgs.git
    pkgs.docker
    pkgs.docker-compose
    pkgs.platformio   # untuk ESP32
  ];
  env = {
    FIREBASE_PROJECT = "sazwan-aiot-platform";
    NODE_ENV = "development";
  };
  idx.extensions = [
    "googlecloudtools.firebase-dataconnect-vscode"
    "ms-azuretools.vscode-docker"
    "platformio.platformio-ide"
    "esbenp.prettier-vscode"
  ];
  idx.previews = {
    enable = true;
    previews = {
      web = {
        command = [
          "npm" "run" "dev" "--" "--port" "$PORT" "--host" "0.0.0.0"
        ];
        manager = "web";
        env = {
          PORT = "3000";
          FIREBASE_AUTH_EMULATOR_HOST = "localhost:9099";
          FIRESTORE_EMULATOR_HOST = "localhost:8080";
        };
      };
    };
  };
  services = {
    firebase = {
      emulators = {
        enabled = true;
        ports = {
          auth = 9099;
          firestore = 8080;
          functions = 5001;
          storage = 9199;
          ui = 4000;
        };
      };
    };
    postgres = {
      enable = true;
      initialData = {
        databases = [{ name = "firebase_dataconnect"; }];
      };
    };
  };
}
```

